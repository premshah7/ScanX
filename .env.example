# Database (Neon, Local PostgreSQL, etc.)
DATABASE_URL="DB_LINK"

# Authentication (NextAuth.js)
# Generate one here: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Security & QR Codes
# IMPORTANT: This secret MUST be the same in your Flutter app's constants.
NEXT_PUBLIC_QR_SECRET="your_secure_random_qr_secret"

# Application URL (Used for referer checks and base paths)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email Configuration (SMTP - used for OTP and alerts)
EMAIL_SERVER_HOST="smtp.ethereal.email"
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER="your_smtp_username"
EMAIL_SERVER_PASSWORD="your_smtp_password"
EMAIL_FROM="\"ScanX Support\" <noreply@scanx.local>"

# Security Filtering
# Leave empty to allow all domains, or set e.g., "@university.edu"
ALLOWED_EMAIL_DOMAIN=""

# Cron Job Security (For cleaning up expired sessions)
CRON_SECRET="your_cron_token_here"

# Environment State
NODE_ENV="development"


# Not necessary !!!!
# Pusher Channels (Real-Time Attendance Updates)
# Sign up at https://pusher.com → Create App → App Keys tab
PUSHER_APP_ID="your_pusher_app_id"
PUSHER_KEY="your_pusher_key"
PUSHER_SECRET="your_pusher_secret"
PUSHER_CLUSTER="ap2"
NEXT_PUBLIC_PUSHER_KEY="your_pusher_key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"
